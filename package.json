{
  "name": "notion-web-clipper",
  "description": "AI-assisted Chrome extension for saving web pages to Notion databases.",
  "version": "1.0.2",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/c-wenlong/notion-web-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/c-wenlong/notion-web-assistant/issues"
  },
  "homepage": "https://github.com/c-wenlong/notion-web-assistant#readme",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "audit:dependencies": "pnpm audit",
    "validate:extension": "node scripts/validate-extension.mjs",
    "compile": "tsc --noEmit",
    "test": "node scripts/build-test.mjs && node --test /tmp/notion-web-assistant.test.cjs",
    "verify": "pnpm test && pnpm compile && pnpm build && pnpm validate:extension && pnpm --dir tools/ui-preview --ignore-workspace compile && pnpm --dir tools/ui-preview --ignore-workspace build",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "defuddle": "0.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "esbuild": "0.28.1",
    "linkedom": "0.18.13",
    "typescript": "^5.6.0",
    "wxt": "^0.20.27"
  }
}
